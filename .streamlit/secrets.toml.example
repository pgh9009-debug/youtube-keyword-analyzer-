# Streamlit Cloud secrets 설정 예시
# 이 파일을 복사해서 secrets.toml로 만들지 마세요 (로컬 개발 시)
# Streamlit Cloud 대시보드의 Settings → Secrets 탭에 아래 내용을 붙여넣으세요

# YouTube Data API 키
YOUTUBE_API_KEY = "여기에_유튜브_API_키_입력"

# Anthropic Claude API 키
ANTHROPIC_API_KEY = "sk-ant-..."

# 초기 계정 목록 (재시작해도 유지됨)
# 비밀번호 해시 생성: python3 -c "import hashlib; print(hashlib.sha256('비밀번호'.encode()).hexdigest())"
INITIAL_USERS = '{"admin": {"password": "해시값", "name": "관리자"}, "팀원ID": {"password": "해시값", "name": "팀원이름"}}'
